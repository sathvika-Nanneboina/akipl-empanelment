{
  "name": "contractor-empanelment-system",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "npm install && npm install --prefix backend && npm install --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "npm run build --prefix frontend",
    "prisma:generate": "npm run generate --prefix backend",
    "prisma:migrate": "npm run db:push --prefix backend",
    "prisma:seed": "npm run seed --prefix backend",
    "setup": "npm run install:all && npm run prisma:migrate && npm run prisma:seed"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
